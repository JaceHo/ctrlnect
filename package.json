{
  "name": "ctrlnect",
  "version": "0.1.0",
  "description": "Control your AI agents. Connect from anywhere. Self-hosted web UI for Claude autonomous coding agents.",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JaceHo/ctrlnect.git"
  },
  "keywords": [
    "ctrlnect",
    "claude",
    "claude-code",
    "agent",
    "ai",
    "coding-assistant",
    "web-ui",
    "claude-agent-sdk",
    "anthropic",
    "self-hosted"
  ],
  "workspaces": ["shared", "server", "client"],
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun run --watch server/src/index.ts",
    "dev:client": "cd client && bunx vite",
    "build": "cd client && bunx vite build",
    "typecheck": "tsc --build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
